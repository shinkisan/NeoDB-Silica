# ---------------------------------------------------------------------------
# NeoDB Silica environment configuration
#
# Copy this file to `.env.local` and fill in the values you need. Only the
# NeoDB section is required for a working deployment; every integration below
# is optional.
#
# Brand identity (site name, colors, contact email, etc) is NOT set
# here — edit `src/site.config.ts` and replace the assets in `public/` instead.
# ---------------------------------------------------------------------------

# --- NeoDB (required) ------------------------------------------------------

# The NeoDB instance used for public catalog data and OAuth login.
# Defaults to https://neodb.social when unset.
NEODB_DEFAULT_INSTANCE=https://neodb.social

# Optional: use a different instance for OAuth login than for catalog data.
# Falls back to NEODB_DEFAULT_INSTANCE when unset.
# NEODB_AUTH_INSTANCE=https://neodb.social

# Secret used to seal/open session and OAuth cookies (AES-256-GCM).
# REQUIRED for login. Generate one with: openssl rand -base64 32
NEODB_SESSION_SECRET=replace-with-a-long-random-secret

# Public origin used to build OAuth redirect URIs. Falls back to
# SITE_PUBLIC_ORIGIN. REQUIRED in production — set this or SITE_PUBLIC_ORIGIN
# below, or login is refused rather than deriving the redirect URI from the
# request's Host header (which a misconfigured reverse proxy could let an
# attacker spoof). Not enforced in development.
# NEODB_REDIRECT_ORIGIN=https://your-domain.example

# --- Optional: TMDB enrichment ---------------------------------------------
# Enables high-res posters, stills, clickable cast/credits, and the home
# now-playing / upcoming discovery rails. When unset, the app falls back to
# NeoDB data and hides the TMDB-only surfaces. Provide either a v3 API key or
# a v4 access token.
# TMDB_API_KEY=
# TMDB_ACCESS_TOKEN=

# --- Optional: Azure Translator --------------------------------------------
# Enables the in-app comment/activity translation button. When unset, the
# translate action is hidden entirely. KEY and ENDPOINT are both required to
# enable it; REGION is optional depending on your Azure resource.
# AZURE_TRANSLATOR_KEY=
# AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
# AZURE_TRANSLATOR_REGION=

# --- Optional: SEO / search indexing ---------------------------------------
# Canonical public origin for metadata (defaults to siteConfig.publicOrigin,
# then to http://localhost:3000 if that's empty too).
# SITE_PUBLIC_ORIGIN=https://your-domain.example
# Search indexing is enabled automatically when VERCEL_ENV=production. For a
# non-Vercel production deployment, opt in explicitly:
# BIELU_ALLOW_INDEXING=1
# GOOGLE_SITE_VERIFICATION=
# BING_SITE_VERIFICATION=

# --- Optional: outbound proxy ----------------------------------------------
# Route server-side fetches to NeoDB through a proxy. Falls back to the
# standard HTTPS_PROXY / HTTP_PROXY variables when unset.
# NEODB_PROXY_URL=http://127.0.0.1:7897

# --- Optional: reverse proxy trust ------------------------------------------
# Rate limiting keys requests by the x-forwarded-for / x-real-ip header, which
# is only trustworthy if a reverse proxy in front of this app overwrites
# whatever the client sends (true on Vercel, the default assumption here).
# If you're exposing this app directly to the internet, or your reverse proxy
# doesn't strip inbound client-supplied values for these headers, set this to
# 0 — otherwise a client can spoof a fresh IP on every request to bypass rate
# limits. Rate limiting still applies when disabled, just per-deployment
# instead of per-visitor (a single shared limit for everyone).
# TRUST_PROXY_HEADERS=0

# --- Optional: misc ---------------------------------------------------------
# Cover images from the NeoDB instance are, by default, re-fetched server-side
# through /api/image/cover, resized/recompressed to webp with sharp, and served
# from your own origin with a long cache lifetime — this is an in-app image
# proxy/optimizer, unrelated to the NEODB_PROXY_URL network egress proxy above
# (though that egress proxy, if set, is also used for this re-fetch). Set to 0
# to disable it and link directly to the original NeoDB image URLs instead.
# COVER_IMAGE_PROXY=0
# Enable verbose [neodb-auth] logging.
# NEODB_DEBUG=1
